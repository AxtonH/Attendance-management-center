# Copy to .env and fill in real values. Never commit .env.

# --- Backend ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role bypasses RLS; backend-only
APP_TIMEZONE=Asia/Amman
APP_LOG_LEVEL=INFO
CONFIG_DIR=./config
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Odoo (phase 2) ---
# Leave ODOO_URL empty to keep running on the phase-1 punch-derived roster.
ODOO_URL=https://your-odoo.example.com
ODOO_DB=your_database
ODOO_USERNAME=integration@prezlab.com
ODOO_PASSWORD=
# How long the cached Odoo employee list stays valid (seconds). The roster
# changes rarely; 300s keeps the dashboard snappy while bounding staleness.
ODOO_EMPLOYEE_CACHE_TTL=300
# Page size for batched search_read calls against hr.employee.
ODOO_BATCH_SIZE=500

# --- Frontend ---
# Public: baked into the browser bundle, so only the proxy URL goes here.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
